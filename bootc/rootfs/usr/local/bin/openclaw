#!/usr/bin/env bash
set -euo pipefail

container_name="${OPENCLAW_CONTAINER:-openclaw}"
args=()

while (($# > 0)); do
  case "$1" in
    --container)
      if (($# < 2)); then
        echo "Missing value for --container." >&2
        exit 2
      fi
      container_name="$2"
      shift 2
      ;;
    --container=*)
      container_name="${1#--container=}"
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ "$(id -un)" != "openclaw" ]]; then
  if ! command -v sudo >/dev/null 2>&1; then
    echo "Run as openclaw, or install sudo so this wrapper can delegate to the openclaw user." >&2
    exit 1
  fi
  exec sudo -iu openclaw -- /usr/local/bin/openclaw --container "$container_name" "${args[@]}"
fi

if ! podman inspect --format '{{.State.Running}}' "$container_name" 2>/dev/null | grep -qx true; then
  echo "OpenClaw container '$container_name' is not running." >&2
  echo "Try: systemctl --user start openclaw.service" >&2
  exit 1
fi

exec_args=(exec)
if [[ -t 0 && -t 1 ]]; then
  exec_args+=(-it)
else
  exec_args+=(-i)
fi

exec podman "${exec_args[@]}" "$container_name" openclaw "${args[@]}"
