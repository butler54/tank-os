#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -un)" == "openclaw" ]]; then
  exec /usr/libexec/tank-os/sync-podman-secrets "$@"
fi

if ! command -v sudo >/dev/null 2>&1; then
  echo "Run as openclaw, or install sudo so this wrapper can delegate to the openclaw user." >&2
  exit 1
fi

exec sudo -iu openclaw -- /usr/libexec/tank-os/sync-podman-secrets "$@"
