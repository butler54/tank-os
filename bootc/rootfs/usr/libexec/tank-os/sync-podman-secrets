#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -un)" != "openclaw" ]]; then
  echo "Run as the openclaw user: sudo -iu openclaw -- /usr/libexec/tank-os/sync-podman-secrets" >&2
  exit 1
fi

quadlet_dropin_dir="$HOME/.config/containers/systemd/openclaw.container.d"
quadlet_dropin="$quadlet_dropin_dir/10-secrets.conf"
service_gator_dropin_dir="$HOME/.config/containers/systemd/service-gator.container.d"
service_gator_dropin="$service_gator_dropin_dir/10-secrets.conf"
config_file="$HOME/.openclaw/openclaw.json"

secret_exists() {
  podman secret inspect "$1" >/dev/null 2>&1
}

mkdir -p "$quadlet_dropin_dir" "$service_gator_dropin_dir" "$HOME/.openclaw"

openclaw_secret_lines=()
add_openclaw_secret() {
  local name="$1"
  local env="$2"
  if secret_exists "$name"; then
    openclaw_secret_lines+=("Secret=${name},type=env,target=${env}")
  fi
}

add_openclaw_secret "anthropic_api_key" "ANTHROPIC_API_KEY"
add_openclaw_secret "openai_api_key" "OPENAI_API_KEY"
add_openclaw_secret "gemini_api_key" "GEMINI_API_KEY"
add_openclaw_secret "google_api_key" "GOOGLE_API_KEY"
add_openclaw_secret "openrouter_api_key" "OPENROUTER_API_KEY"
add_openclaw_secret "model_endpoint_api_key" "MODEL_ENDPOINT_API_KEY"
add_openclaw_secret "telegram_bot_token" "TELEGRAM_BOT_TOKEN"

{
  printf '[Container]\n'
  if ((${#openclaw_secret_lines[@]} > 0)); then
    printf '%s\n' "${openclaw_secret_lines[@]}"
  fi
} >"$quadlet_dropin"

service_gator_secret_lines=()
add_service_gator_secret() {
  local name="$1"
  if secret_exists "$name"; then
    service_gator_secret_lines+=("Secret=${name}")
  fi
}

add_service_gator_secret "gh_token"
add_service_gator_secret "gitlab_token"
add_service_gator_secret "forgejo_token"
add_service_gator_secret "jira_api_token"

{
  printf '[Container]\n'
  if ((${#service_gator_secret_lines[@]} > 0)); then
    printf '%s\n' "${service_gator_secret_lines[@]}"
  fi
} >"$service_gator_dropin"

if command -v python3 >/dev/null 2>&1; then
  python3 - "$config_file" "${openclaw_secret_lines[@]}" <<'PY'
import json
import os
import sys

path = sys.argv[1]
secret_lines = sys.argv[2:]

env_targets = []
for line in secret_lines:
    marker = ",type=env,target="
    if marker in line:
        env_targets.append(line.split(marker, 1)[1])
env_targets = list(dict.fromkeys(env_targets))

GOOGLE_BASE_URL = "https://generativelanguage.googleapis.com/v1beta"
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"
ANTHROPIC_BASE_URL = "https://api.anthropic.com"
OPENAI_BASE_URL = "https://api.openai.com/v1"


def env_secret_ref(env_id):
    return {"source": "env", "provider": "default", "id": env_id}


def add_model(provider, model_id, name=None):
    if not model_id:
        return
    models = provider.setdefault("models", [])
    if not isinstance(models, list):
        models = []
        provider["models"] = models
    normalized = model_id.split("/", 1)[1] if "/" in model_id else model_id
    for item in models:
        if isinstance(item, dict) and item.get("id") == normalized:
            return
    models.append({"id": normalized, "name": name or normalized})


def is_secret_ref(value, env_id):
    return value == env_secret_ref(env_id)


def cleanup_or_complete_builtin_provider(provider_id, env_id, base_url, api, model_id):
    provider = models.get(provider_id)
    if not isinstance(provider, dict):
        return

    provider_keys = {key for key, value in provider.items() if value is not None}
    if provider_keys <= {"apiKey"} and is_secret_ref(provider.get("apiKey"), env_id):
        del models[provider_id]
        return

    provider["baseUrl"] = provider.get("baseUrl") or base_url
    provider["api"] = provider.get("api") or api
    if not isinstance(provider.get("models"), list):
        provider["models"] = []
    add_model(provider, model_id)

if os.path.exists(path):
    with open(path, "r", encoding="utf-8") as fh:
        data = json.load(fh)
else:
    data = {}

gateway = data.setdefault("gateway", {})
gateway.setdefault("mode", "local")

providers = data.setdefault("secrets", {}).setdefault("providers", {})
if env_targets:
    providers.setdefault("default", {"source": "env"})

models = data.setdefault("models", {}).setdefault("providers", {})

if "ANTHROPIC_API_KEY" in env_targets:
    cleanup_or_complete_builtin_provider(
        "anthropic",
        "ANTHROPIC_API_KEY",
        ANTHROPIC_BASE_URL,
        "anthropic-messages",
        "claude-opus-4-6",
    )

if "OPENAI_API_KEY" in env_targets:
    cleanup_or_complete_builtin_provider(
        "openai",
        "OPENAI_API_KEY",
        OPENAI_BASE_URL,
        "openai-responses",
        "gpt-5.4",
    )

google_env = "GEMINI_API_KEY" if "GEMINI_API_KEY" in env_targets else None
if not google_env and "GOOGLE_API_KEY" in env_targets:
    google_env = "GOOGLE_API_KEY"
if google_env:
    google = models.setdefault("google", {})
    google["baseUrl"] = google.get("baseUrl") or GOOGLE_BASE_URL
    google["api"] = google.get("api") or "google-generative-ai"
    google["apiKey"] = env_secret_ref(google_env)
    add_model(google, "gemini-3.1-pro-preview")

if "OPENROUTER_API_KEY" in env_targets:
    openrouter = models.setdefault("openrouter", {})
    openrouter["baseUrl"] = openrouter.get("baseUrl") or OPENROUTER_BASE_URL
    openrouter["api"] = openrouter.get("api") or "openai-completions"
    openrouter["apiKey"] = env_secret_ref("OPENROUTER_API_KEY")
    add_model(openrouter, "auto")

if "TELEGRAM_BOT_TOKEN" in env_targets:
    telegram = data.setdefault("channels", {}).setdefault("telegram", {})
    telegram.setdefault("botToken", env_secret_ref("TELEGRAM_BOT_TOKEN"))

with open(path, "w", encoding="utf-8") as fh:
    json.dump(data, fh, indent=2)
    fh.write("\n")
PY
else
  echo "python3 not found; wrote Quadlet drop-ins but did not update $config_file" >&2
fi

systemctl --user daemon-reload

cat <<EOF
Wrote:
  $quadlet_dropin
  $service_gator_dropin

Detected OpenClaw secrets: ${#openclaw_secret_lines[@]}
Detected service-gator secrets: ${#service_gator_secret_lines[@]}

Restart services when ready:
  systemctl --user restart openclaw.service
  systemctl --user restart service-gator.service
EOF
